Screen {
    layout: vertical;
}

#summary-bar {
    border: round $accent;
    border-title-color: $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#summary-context {
    height: auto;
    margin-right: 2;
    width: auto;
}

#summary-namespace {
    height: auto;
    width: auto;
}

#breadcrumb {
    height: auto;
    margin: 0 1;
    padding: 0 1;
}

#back-button {
    display: none;
    margin-left: 1;
    width: auto;
}

#explorer {
    height: 1fr;
    margin: 0 1 1 1;
}

#pod-panel {
    border: round $accent;
    height: 1fr;
    margin-right: 1;
    width: 2fr;
}

#details-panel {
    border: round $accent;
    height: 1fr;
    width: 1fr;
}

.panel-title {
    background: $primary;
    color: $background;
    padding: 0 1;
    text-style: bold;
}

#pod-table {
    height: 1fr;
}

#pod-details {
    height: 1fr;
    padding: 1;
}

#command-area {
    display: none;
    dock: bottom;
    height: auto;
    margin: 0 1 1 1;
}

#command-bar {
    height: 3;
}

#command-prefix {
    border: round $accent;
    content-align: center middle;
    height: 3;
    min-width: 3;
    width: 3;
}

#command-input {
    border: round $accent;
    height: 3;
    margin-left: 1;
    width: 1fr;
}

#command-suggestions {
    border: round $accent;
    display: none;
    height: auto;
    margin-top: 1;
    max-height: 6;
    padding: 0 1;
}

#about-panel {
    background: $panel;
    border: round $accent;
    height: auto;
    margin: 8 24;
    padding: 1 2;
    width: auto;
}

LogsScreen {
    layout: vertical;
}

#logs-title {
    border: round $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#logs-controls {
    height: 3;
    margin: 1 1 0 1;
}

#logs-since {
    border: round $accent;
    height: 3;
    width: 24;
}

#logs-filter {
    border: round $accent;
    height: 3;
    margin-left: 1;
    width: 1fr;
}

#logs-output {
    border: round $accent;
    height: 1fr;
    margin: 1;
    padding: 0 1;
    width: 2fr;
}

#logs-detail-panel {
    border: round $accent;
    display: none;
    height: 1fr;
    margin: 1 1 1 0;
    width: 1fr;
}

#logs-detail-content {
    height: 1fr;
    padding: 1;
}

#confirm-dialog {
    background: $panel;
    border: round $accent;
    height: auto;
    margin: 8 24;
    padding: 1 2;
    width: auto;
}

#confirm-title {
    text-style: bold;
}

#confirm-actions {
    height: auto;
    margin-top: 1;
}

#manifest-title {
    border: round $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#manifest-controls {
    height: 3;
    margin: 1 1 0 1;
}

#manifest-search {
    border: round $accent;
    height: 3;
    width: 1fr;
}

#manifest-match-status {
    color: $text-muted;
    content-align: center middle;
    height: 3;
    margin-left: 1;
    width: auto;
}

#manifest-panel {
    border: round $accent;
    height: 1fr;
    margin: 1;
    padding: 0 1;
}

#describe-title {
    border: round $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#describe-controls {
    height: 3;
    margin: 1 1 0 1;
}

#describe-search {
    border: round $accent;
    height: 3;
    width: 1fr;
}

#describe-match-status {
    color: $text-muted;
    content-align: center middle;
    height: 3;
    margin-left: 1;
    width: auto;
}

#describe-body {
    height: 1fr;
    margin: 1;
}

#describe-panel {
    border: round $accent;
    height: 1fr;
    padding: 0 1;
    width: 2fr;
}

#describe-events-panel {
    border: round $accent;
    height: 1fr;
    margin-left: 1;
    width: 1fr;
}

#describe-events {
    height: 1fr;
    padding: 1;
}

#events-title {
    border: round $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#events-controls {
    height: 3;
    margin: 1 1 0 1;
}

#events-search {
    border: round $accent;
    height: 3;
    width: 1fr;
}

#events-match-status {
    color: $text-muted;
    content-align: center middle;
    height: 3;
    margin-left: 1;
    width: auto;
}

#events-body {
    height: 1fr;
    margin: 1;
}

#events-table {
    border: round $accent;
    height: 1fr;
    width: 2fr;
}

#events-detail-panel {
    border: round $accent;
    display: none;
    height: 1fr;
    margin-left: 1;
    width: 1fr;
}

#events-detail-content {
    height: 1fr;
    padding: 1;
}

#config-title {
    border: round $accent;
    height: auto;
    margin: 1 1 0 1;
    padding: 0 1;
}

#config-panel {
    border: round $accent;
    height: 1fr;
    margin: 1;
    padding: 1;
}

.config-section {
    height: auto;
    margin-bottom: 1;
}

.config-row {
    height: auto;
    margin-bottom: 1;
    margin-top: 1;
}

.config-label {
    padding: 1 2 0 1;
    width: 20;
}
